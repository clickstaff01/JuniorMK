# ─────────────────────────────────────────────
# Copy this file to .env.local for local dev.
# Never commit .env.local — it contains secrets.
# ─────────────────────────────────────────────

# Database (local dev via docker compose)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/clickbroker_dev"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""   # generate: openssl rand -base64 32
AUTH_SECRET=""       # same value as NEXTAUTH_SECRET — required by NextAuth v5

# Google OAuth (optional — enables "Sign in with Google")
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: https://<your-domain>/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Comma-separated email domains allowed to auto-provision via Google.
# Users from other domains can only log in if an admin has pre-created them.
# Example: "clickbroker.co.th,clickinsure.co.th"
AUTH_ALLOWED_DOMAINS=""

# Email (Resend)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="no-reply@clickbroker.co.th"

# File uploads (UploadThing)
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# Monitoring
SENTRY_DSN=""
POSTHOG_KEY=""
POSTHOG_HOST="https://app.posthog.com"

# Cron security
CRON_SECRET=""   # generate: openssl rand -base64 32

# Feature flags
FEATURE_ANALYTICS="false"
FEATURE_NOTIFY_CRON="false"
